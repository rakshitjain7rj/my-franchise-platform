# =============================================================================
# Environment template for the Dokploy production deploy of Cake Break.
#
# Copy these into Dokploy's Environment tab (do NOT commit real secrets).
# Domains are pre-filled; replace every CHANGE_ME with a strong value.
#
# Generate secrets with:  openssl rand -base64 32
# =============================================================================

# ----- PostgreSQL (the `db` service) ----------------------------------------
POSTGRES_USER=medusa
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password
POSTGRES_DB=medusa

# ----- Backend: database / cache --------------------------------------------
# DATABASE_URL must match the POSTGRES_* values above and point at host `db`.
DATABASE_URL=postgres://medusa:CHANGE_ME_strong_db_password@db:5432/medusa
# The bundled Postgres has no SSL. Keep false. Set true only for a managed DB.
DATABASE_SSL=false
REDIS_URL=redis://redis:6379

# ----- Backend: secrets (rotate these!) -------------------------------------
JWT_SECRET=CHANGE_ME_openssl_rand_base64_32
COOKIE_SECRET=CHANGE_ME_openssl_rand_base64_32

# ----- Backend: public URL + CORS -------------------------------------------
# Public base URL of the backend (admin lives at <this>/app).
MEDUSA_BACKEND_URL=https://cakebreak-backend.codeation.io
# Browser-facing origins. Storefront calls the backend from cakebreak.codeation.io;
# the admin SPA calls it from the backend domain itself.
STORE_CORS=https://cakebreak.codeation.io
ADMIN_CORS=https://cakebreak-backend.codeation.io
AUTH_CORS=https://cakebreak.codeation.io,https://cakebreak-backend.codeation.io

# ----- One-time data seeding (optional) -------------------------------------
# Set RUN_SEED=true for the FIRST deploy only, then set back to false & redeploy.
RUN_SEED=false
SEED_SCRIPTS=seed-franchise-data.ts seed-catalogue.ts

# ----- Storefront (BUILD-TIME, baked into the client bundle) ----------------
# Must be the PUBLIC backend URL — it runs in the visitor's browser.
NEXT_PUBLIC_MEDUSA_BACKEND_URL=https://cakebreak-backend.codeation.io
# Create this in the admin (Settings > Publishable API Keys) after first deploy,
# then set it here and redeploy the storefront so the new value is baked in.
NEXT_PUBLIC_MEDUSA_PUBLISHABLE_KEY=pk_CHANGE_ME
# Live franchise ID used when no franchise cookie / subdomain is present.
# Set after first seed (Super Admin → Franchises). Optional for default-store
# bootstrap; the storefront also falls back to the first active location.
NEXT_PUBLIC_DEFAULT_FRANCHISE_ID=
